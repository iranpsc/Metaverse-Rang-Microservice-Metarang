{
  "annotations": { "list": [] },
  "editable": true,
  "links": [
    { "title": "Overview", "type": "link", "url": "/d/overview-dashboard", "icon": "dashboard" }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Database",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": { "showHeader": true },
      "targets": [
        { "expr": "db_connection_status{service!=\"legacy\"}", "format": "table", "instant": true, "refId": "A" }
      ],
      "title": "Database Connection Status",
      "type": "table"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "db_connection_latency_seconds{service!=\"legacy\"}", "legendFormat": "{{service}}", "refId": "A" }
      ],
      "title": "Database Connection Latency",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "db_connection_pool_open{service!=\"legacy\",service!=\"health-check-service\"}", "legendFormat": "Open {{service}}", "refId": "A" },
        { "expr": "db_connection_pool_in_use{service!=\"legacy\",service!=\"health-check-service\"}", "legendFormat": "In Use {{service}}", "refId": "B" },
        { "expr": "db_connection_pool_idle{service!=\"legacy\",service!=\"health-check-service\"}", "legendFormat": "Idle {{service}}", "refId": "C" }
      ],
      "title": "Database Connection Pool",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 5,
      "title": "Cache (Redis)",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 90 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 18 },
      "id": 6,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      },
      "targets": [
        { "expr": "cache_hit_rate", "legendFormat": "Hit Rate", "refId": "A" }
      ],
      "title": "Cache Hit Rate",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 18 },
      "id": 7,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "cache_status", "legendFormat": "Redis", "refId": "A" }
      ],
      "title": "Cache Health",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 18 },
      "id": 8,
      "options": {
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        { "expr": "cache_memory_usage_bytes / 1024 / 1024", "legendFormat": "Memory MB", "refId": "A" }
      ],
      "title": "Cache Memory",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "showPoints": "never" },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(cache_hits_total[5m])", "legendFormat": "Hits/s", "refId": "A" },
        { "expr": "rate(cache_misses_total[5m])", "legendFormat": "Misses/s", "refId": "B" }
      ],
      "title": "Cache Hits & Misses Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 10,
      "title": "External APIs",
      "type": "row"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "id": 11,
      "options": { "showHeader": true },
      "targets": [
        { "expr": "external_api_status", "format": "table", "instant": true, "refId": "A" }
      ],
      "title": "External API Availability",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["dependencies", "database", "cache", "monitoring"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Dependencies - DB, Cache & APIs",
  "uid": "dependencies-dashboard",
  "version": 1
}
