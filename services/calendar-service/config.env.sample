# Calendar Service Configuration
PROJECT_LOCALE=EN

# gRPC Server (internal / service-to-service)
GRPC_PORT=50059

# HTTP Server (Kong upstream for /api/calendar)
HTTP_PORT=8060

# Public base URL for pagination links (Kong gateway)
APP_URL=http://localhost:8000

# Auth service (token validation for protected HTTP routes)
AUTH_SERVICE_ADDR=auth-service:50051

# Metrics
METRICS_PORT=9090

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=metarang_db
DB_USER=calendar_service
DB_PASSWORD=calendar_password
