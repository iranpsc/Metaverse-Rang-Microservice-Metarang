# App Locale
PROJECT_LOCALE=EN

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=metarang_db

# gRPC Server Configuration
GRPC_PORT=50062

# Commercial service (wallet balance updates after payment)
COMMERCIAL_SERVICE_ADDR=commercial-service:50052

# Sadad Payment Gateway Configuration (Bank Melli)
# Single terminal with MultiplexingData amount-based routing

# Enable BankTest sandbox for local/development (https://banktest.ir/sadad-melli-test-gateway/)
# When true, uses BankTest URLs:
#   PaymentRequest: https://sandbox.banktest.ir/melli/sadad.shaparak.ir/VPG/api/v0/Request/PaymentRequest
#   Verify:         https://sandbox.banktest.ir/melli/sadad.shaparak.ir/VPG/api/v0/Advice/Verify
#   Purchase:       https://sandbox.banktest.ir/melli/sadad.shaparak.ir/VPG/Purchase
SADAD_SANDBOX=false

# Production credentials (from Sadad PSP)
SADAD_MERCHANT_ID=your_merchant_id_here
SADAD_TERMINAL_ID=your_terminal_id_here
SADAD_TRANSACTION_KEY=your_base64_transaction_key_here

# Sandbox credentials example (register at https://banktest.ir — values from your test gateway panel):
# SADAD_SANDBOX=true
# SADAD_MERCHANT_ID=46645
# SADAD_TERMINAL_ID=GBHDTY98
# SADAD_TRANSACTION_KEY=MzVlOTU1NmVhYWM1MDrhOWFlYTVjMDJi

# MultiplexingData IbanNumber values (assigned by Sadad per sub-account)
SADAD_PAYMENT_IDENTITY_RIAL=your_rial_iban_number_here
SADAD_PAYMENT_IDENTITY_NON_RIAL=your_non_rial_iban_number_here

# Frontend URL for post-payment redirects (React/Vite local dev: http://localhost:5173)
# Used ONLY after /api/order/callback verifies payment and credits the wallet.
FRONTEND_URL=http://localhost:5173

# API base URL (Kong / gateway). Sadad must redirect users here first — NOT to FRONTEND_URL.
PROJECT_URL=http://localhost:8000

# Sadad ReturnUrl sent to the gateway. Must be the API callback endpoint.
SADAD_CALLBACK_URL=${PROJECT_URL}/api/order/callback

# Port applied to the Sadad callback host (e.g. grpc-gateway HTTP port when PROJECT_URL uses Kong).
# When set, replaces any port from SADAD_CALLBACK_URL / PROJECT_URL.
SADAD_CALLBACK_PORT=8080
