# App Locale
PROJECT_LOCALE=EN

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_DATABASE=metarang

# Server Configuration
GRPC_PORT=50052
HTTP_PORT=8080
AUTH_SERVICE_ADDR=auth-service:50051

# Inter-service authentication (required for wallet mutation RPCs)
INTERNAL_SERVICE_SECRET=change-me-in-production

# Optional inter-service TLS/mTLS (see scripts/generate-grpc-certs.sh)
GRPC_TLS_ENABLED=false
