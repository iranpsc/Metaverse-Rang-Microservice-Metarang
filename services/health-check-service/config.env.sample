# Health Check Service — optional overrides (defaults match docker-compose MySQL/Redis)
# Copy to config.env (or run scripts/setup-env-files from repo root).

# MySQL (shared schema used for dependency checks)
DB_HOST=localhost
DB_PORT=3306
DB_USER=metarang_user
DB_PASSWORD=metarang_password
DB_DATABASE=metarang_db

# Redis metrics
REDIS_URL=redis://localhost:6379

# External checks (leave empty to skip)
PARSIAN_API_URL=
ISTIO_METRICS_URL=
