# Shared configuration for Docker Compose (repo root .env)
# Copy to .env in the repo root:  cp sentry.env.sample .env
# Docker Compose injects these into services automatically.
# Do not add SENTRY_* vars to individual service config.env files.

# Public API base URL (Kong gateway). Used by Swagger UI in production.
APP_URL=http://localhost:8000

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0
